# =============================================================================
# Vouch environment. Copy to `.env.local` (gitignored) and fill in.
# Vouch runs fully on the deterministic mock with NONE of these set — they only
# activate live mode against the real OKX.AI marketplace.
#
# SECURITY: never commit real values; never paste secrets into chat. The code
# reads these from the environment — the actual values only ever live in
# `.env.local` on your machine (and in your deploy host's secret manager).
# =============================================================================

# --- 1. OKX Onchain OS API credentials (web3.okx.com/dev-portal) --------------
# Created under a Project → API key. Auth needs all four together.
OKX_PROJECT_ID=
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# --- 2. Vouch's on-chain agent wallet (X Layer, chainId 196) ------------------
# Pick ONE path:
#  (A) OKX Agentic Wallet — created at okx.ai via email login. Keys live in a
#      TEE (no raw export); the agent signs through a session. Preferred for the
#      marketplace-native path. Put the session/agent token here:
OKX_AGENT_SESSION=
#  (B) Self-custodial hot wallet — a DEDICATED throwaway key you export from a
#      fresh MetaMask account. Used for local-key x402 signing. NEVER your main
#      wallet. Leave blank if using (A).
OKX_AGENT_PRIVATE_KEY=

# --- 3. Model key for the multi-model scoring panel ---------------------------
# Anthropic (console.anthropic.com) or OpenAI (platform.openai.com).
VOUCH_LLM_API_KEY=

# --- 4. Public base URL (x402 `resource` fields + share links) ----------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000
