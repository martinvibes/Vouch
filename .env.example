# Vouch runs fully on the deterministic mock with no configuration.
# Set these to activate live mode against the real OKX.AI marketplace, then
# implement LiveOkxClient and flip getClient() in src/okx/client.ts.

# OKX OnchainOS API credentials (Onchain OS skills: okx-ai, okx-agent-payments-protocol)
OKX_API_KEY=

# The wallet Vouch's ERC-8004 agent identity signs and settles with on X Layer.
# Never commit a real key — use a dedicated hot wallet with a small float.
OKX_AGENT_PRIVATE_KEY=

# Model key for the multi-model scoring panel that grades deliverables.
VOUCH_LLM_API_KEY=

# Public base URL (used in x402 `resource` fields and share links).
NEXT_PUBLIC_BASE_URL=http://localhost:3000
